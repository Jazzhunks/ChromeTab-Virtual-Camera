{
  "manifest_version": 3,
  "name": "Chrome Tab Virtual Camera",
  "version": "1.0.0",
  "description": "Exposures any Chrome tab as a selectable Web Camera source in Zoom, Google Meet, Teams, and Discord without OBS.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Tab Virtual Camera"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
